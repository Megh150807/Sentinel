# ═══════════════════════════════════════════════════
#  SENTINEL-V1 — .gitignore
#  Covers: C++, Flutter/Dart, Python, GCP, Firebase
# ═══════════════════════════════════════════════════

# ─────────────────────────────────────────────────
#  🔴 SECRETS — NEVER COMMIT THESE
# ─────────────────────────────────────────────────
**/service-account.json
**/service_account.json
**/*-service-account.json
**/*_credentials.json
**/credentials.json
**/keyfile.json
**/*.pem
**/*.p12
**/*.pfx
**/*.key
.env
.env.*
!.env.example
**/secrets/
**/secret/

# Firebase / GCP
.firebaserc.local
google-services.json
GoogleService-Info.plist
**/firebase-adminsdk*.json

# ─────────────────────────────────────────────────
#  C++ Build Artifacts
# ─────────────────────────────────────────────────
core_engine/build/
core_engine/**/*.o
core_engine/**/*.a
core_engine/**/*.so
core_engine/**/*.dylib
core_engine/**/*.dll
core_engine/**/*.exe
core_engine/**/*.out
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake

# ─────────────────────────────────────────────────
#  Flutter / Dart
# ─────────────────────────────────────────────────
# Build output
war_room_ui/build/

# Dart tool internals
war_room_ui/.dart_tool/
.dart_tool/

# Flutter generated files
war_room_ui/.flutter-plugins
war_room_ui/.flutter-plugins-dependencies
*.g.dart
*.freezed.dart

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo

# ─────────────────────────────────────────────────
#  Python / ML Pipeline
# ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
venv/
.venv/
env/
*.egg-info/
dist/
*.dist-info/
.pytest_cache/
.mypy_cache/

# ─────────────────────────────────────────────────
#  Firebase Hosting
# ─────────────────────────────────────────────────
.firebase/
# Note: firebase.json and .firebaserc are kept — they're config, not secrets

# ─────────────────────────────────────────────────
#  Zip / Archives (deployment artifacts)
# ─────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# ─────────────────────────────────────────────────
#  OS / Editor Junk
# ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~
*.bak
*.tmp
*.log

# ─────────────────────────────────────────────────
#  Sentinel-Specific — keep these OUT
# ─────────────────────────────────────────────────
# Old/dummy model — only commit the real trained model
xgboost.json

# Skills lock (Antigravity internal)
skills-lock.json